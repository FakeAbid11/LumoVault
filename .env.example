# LumoVault build-time configuration
#
# Telegram API credentials are registered on https://my.telegram.org under the
# LumoVault developer account. They are injected at build time via --dart-define
# and are the single source of truth (see lib/core/tdlib/tdlib_config.dart).
#
# NEVER commit real credentials. Copy this file to `.env` (gitignored) and fill
# in your own values, then pass them through when building/running:
#
#   flutter run \
#     --dart-define=LUMOVAULT_TELEGRAM_API_ID=123456 \
#     --dart-define=LUMOVAULT_TELEGRAM_API_HASH=your_32_char_hex_hash
#
# Or, with a define file:
#
#   flutter run --dart-define-from-file=.env.json
#
# where .env.json contains:
#   {
#     "LUMOVAULT_TELEGRAM_API_ID": 123456,
#     "LUMOVAULT_TELEGRAM_API_HASH": "your_32_char_hex_hash"
#   }

LUMOVAULT_TELEGRAM_API_ID=
LUMOVAULT_TELEGRAM_API_HASH=
